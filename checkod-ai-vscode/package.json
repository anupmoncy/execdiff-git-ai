{
  "name": "checkod-ai-vscode",
  "displayName": "Checkod AI",
  "description": "VSCode extension for Checkod AI CLI integration.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:checkod-ai.assess"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "checkod-ai.assess",
        "title": "Checkod AI: Assess"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.70.0",
    "typescript": "^4.7.0",
    "vscode": "^1.1.38"
  }
}
